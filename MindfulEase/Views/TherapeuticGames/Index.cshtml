@model IEnumerable<MindfulEase.Models.TherapeuticGame>
@{
    ViewBag.Title = "Therapeutic Games & Quizzes";
}

<div class="container my-5">
    <h2 class="text-center text-info mb-4">EXPLORE THERAPEUTIC GAMES & QUIZZES</h2>

    <br />
    <!-- Search Bar -->
    <section class="p-3" style="padding-top: 100px;">
        <div class="d-flex justify-content-center mb-4">
            <form method="GET" style=" width: 100%; background-color: #f8f9fa; padding: 10px; border-radius: 25px; border: 1px solid #ced4da;">
                <div class="input-group mb-3">
                    <input type="text" class="form-control"
                           placeholder="Search topics or keywords" name="search"
                           value="@ViewBag.SearchString" style="border-radius: 20px;">
                    <button class="btn btn-outline-primary" type="submit" style="border-radius: 20px;">Search</button>
                </div>
            </form>
        </div>
    </section>
    <br />

    <!-- My Quizzes -->
    <section class="mb-5">
        <h3 class="mb-3 text-info">📘 My Quizzes</h3>
        <div class="row" >
            @foreach (var quiz in ((List<MindfulEase.Models.Quiz>)ViewBag.QuizzesUser).Take(4))
            {
                <div class="col-6 col-md-4 col-lg-3 mb-4" >
                    <a href="@Url.Action("Show", "Quizzes", new { id = quiz.Id })" class="card shadow-sm text-decoration-none d-flex flex-column" style="border-radius: 20px; height: 100%; border:3px solid #F9C7D1;">
                        <img src="@quiz.Background" class="card-img-top" alt="@quiz.Title" style="height: 180px; object-fit: cover; border-radius: 20px 20px 0 0;">
                        <div class="card-body text-center d-flex flex-column justify-content-between">
                            <h5 class="card-title">@quiz.Title</h5>
                        </div>
                    </a>
                </div>
            }
        </div>
        <a href="@Url.Action("SeeMore", "TherapeuticGames", new { type = "myQuizzes", search = "" })" class="btn btn-outline-secondary" style="border-radius: 30px;">
            See More
        </a>

    </section>

    <!-- All Quizzes -->
    <section class="mb-5">
        <h3 class="mb-3 text-info">📖 Quizzes</h3>
        <div class="row">
            @foreach (var quiz in ((List<MindfulEase.Models.Quiz>)ViewBag.AllQuizzes).Take(4))
            {
                <div class="col-6 col-md-4 col-lg-3 mb-4" >
                    <a href="@Url.Action("Show", "Quizzes", new { id = quiz.Id })" class="card shadow-sm text-decoration-none d-flex flex-column" style="border-radius: 20px; height: 100%; border:3px solid #D7A7D9">
                        <img src="@quiz.Background" class="card-img-top" alt="@quiz.Title" style="height: 180px; object-fit: cover; border-radius: 20px 20px 0 0;">
                        <div class="card-body text-center d-flex flex-column justify-content-between">
                            <h5 class="card-title">@quiz.Title</h5>
                        </div>
                    </a>
                </div>
            }
        </div>
        <a href="@Url.Action("SeeMore", "TherapeuticGames", new { type = "allQuizzes", search = "" })" class="btn btn-outline-secondary" style="border-radius: 30px;">
            See More
        </a>
    </section>

    <!-- All Games -->
    <section class="mb-5">
        <h3 class="mb-3 text-info">🎲 Games</h3>
        <div class="row">
            @foreach (var game in ((List<MindfulEase.Models.TherapeuticGame>)ViewBag.AllGames).Take(4))
            {
                <div class="col-6 col-md-4 col-lg-3 mb-4">
                    <a href="@Url.Action("Play", "TherapeuticGames", new { id = game.Id })" class="card shadow-sm text-decoration-none d-flex flex-column" style="border-radius: 20px; height: 100%; border:3px solid #A8D7E8">
                        <img src="@game.Background" class="card-img-top" alt="@game.Name" style="height: 180px; object-fit: cover; border-radius: 20px 20px 0 0;">
                        <div class="card-body text-center d-flex flex-column justify-content-between">
                            <h5 class="card-title">@game.Name</h5>
                        </div>
                    </a>
                </div>
            }
        </div>
        <a href="@Url.Action("SeeMore", "TherapeuticGames", new { type = "allGames", search = "" })" class="btn btn-outline-secondary" style="border-radius: 30px;">
            See More
        </a>
    </section>
</div>
<br />
<br />
<br />
<style>
    body {
        background: linear-gradient(to bottom, rgba(168, 237, 234, 0.3), rgba(254, 214, 227, 0.3));
        background-attachment: fixed;
        min-height: 100vh;
        margin: 0;
    }


</style>
