@model IEnumerable<MindfulEase.Models.Resource>

<div class="container my-5">
    <h2 class="text-center mb-4">Recommended Resources</h2>

    <!-- Secțiunea pentru Podcasturi Audio -->
    <section class="mb-5">
        <h3 class="mb-3">🎙️ Audio Podcasts</h3>
        <div class="row">
            @foreach (var resource in Model.Where(r => r.ResourceType == "PodcastAudio"))
            {
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card shadow-sm h-100">
                        <div class="card-body">
                            <audio controls class="w-100">
                                <source src="@resource.Link" type="audio/mpeg">
                                Your browser does not support the audio element.
                            </audio>
                            <h5 class="card-title mt-3">@resource.Title</h5>
                            <form method="post" asp-action="ProvideFeedback" asp-route-resourceId="@resource.Id" class="mt-3">
                                <button type="submit" name="isLiked" value="true" class="btn btn-success btn-sm">👍 Like</button>
                                <button type="submit" name="isLiked" value="false" class="btn btn-danger btn-sm">👎 Dislike</button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    </section>

    <!-- Secțiunea pentru Podcasturi Video -->
    <section class="mb-5">
        <h3 class="mb-3">📹 Video Podcasts</h3>
        <div class="row">
            @foreach (var resource in Model.Where(r => r.ResourceType == "PodcastVideo"))
            {
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card shadow-sm h-100">
                        <div class="card-body">
                            <iframe class="embed-responsive-item"
                                    src="@resource.Link"
                                    allowfullscreen
                                    width="100%">
                            </iframe>
                            <h5 class="card-title mt-3">@resource.Title</h5>
                            <form method="post" asp-action="ProvideFeedback" asp-route-resourceId="@resource.Id" class="mt-3">
                                <button type="submit" name="isLiked" value="true" class="btn btn-success btn-sm">👍 Like</button>
                                <button type="submit" name="isLiked" value="false" class="btn btn-danger btn-sm">👎 Dislike</button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    </section>

    <!-- Secțiunea pentru Videoclipuri -->
    <section class="mb-5">
        <h3 class="mb-3">📹 Educational Videos</h3>
        <div class="row">
            @foreach (var resource in Model.Where(r => r.ResourceType == "Video"))
            {
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card shadow-sm h-100">
                        <div class="card-body">
                            <iframe class="embed-responsive-item"
                                    src="@resource.Link"
                                    allowfullscreen
                                    width="100%">
                            </iframe>
                            <h5 class="card-title mt-3">@resource.Title</h5>
                            <form method="post" asp-action="ProvideFeedback" asp-route-resourceId="@resource.Id" class="mt-3">
                                <button type="submit" name="isLiked" value="true" class="btn btn-success btn-sm">👍 Like</button>
                                <button type="submit" name="isLiked" value="false" class="btn btn-danger btn-sm">👎 Dislike</button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    </section>

    <!-- Secțiunea pentru Imagini -->
    <section class="mb-5">
        <h3 class="mb-3">🖼️ Educational Images</h3>
        <div class="row">
            @foreach (var resource in Model.Where(r => r.ResourceType == "Image"))
            {
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card shadow-sm h-100">
                        <img src="@resource.Link" class="card-img-top" alt="@resource.Title">
                        <div class="card-body">
                            <h5 class="card-title">@resource.Title</h5>
                            <form method="post" asp-action="ProvideFeedback" asp-route-resourceId="@resource.Id" class="mt-3">
                                <button type="submit" name="isLiked" value="true" class="btn btn-success btn-sm">👍 Like</button>
                                <button type="submit" name="isLiked" value="false" class="btn btn-danger btn-sm">👎 Dislike</button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    </section>
</div>
