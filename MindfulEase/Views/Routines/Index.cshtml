                                    <button type="submit" class="btn btn-outline-danger btn-sm" style="border-radius: 30px;">🗑️ Delete</button>
                                </form>
                            </div>
                        }<br /> <br />
                        <div class="card-body">
                            <iframe src="@resource.Link" width="100%" height="152" frameborder="0" allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture" allowfullscreen></iframe>

                            <h5 class="card-title mt-3">@resource.Title</h5>
                            @if (ViewBag.UserCurent != null)
                            {
                                <form method="post" asp-action="ProvideFeedback" asp-route-resourceId="@resource.Id" class="mt-3">
                                    <button type="submit" name="isLiked" value="true" class="btn btn-success btn-sm" style="border-radius: 30px;">👍 Like</button>
                                    <button type="submit" name="isLiked" value="false" class="btn btn-danger btn-sm" style="border-radius: 30px;">👎 Dislike</button>
                                </form>
                            }
                            
                        </div>
