@model IEnumerable<MindfulEase.Models.Resource>

<div class="container my-5">
    <h2 class="text-center mb-4">Resources</h2>
    <a href="@Url.Action("Index", "Routines")" style="font-size: 1.2em; color: #01baa3; text-decoration: none;">
        👈 Back
    </a>
    <br /> <br />
    <div class="row">
        @foreach (var resource in Model)
        {
            <div class="col-6 col-md-4 col-lg-3 mb-4">
                <div class="card shadow-sm h-100 d-flex flex-column justify-content-center">
                    @if (ViewBag.EsteAdmin || ViewBag.EsteModerator)
                    {
                        <div class="d-flex justify-content-between" style="position: absolute; top: 10px; left: 10px; right: 10px; z-index: 10;">
                            <a href="@Url.Action("Edit", "Resource", new { id = resource.Id })" class="btn btn-outline-info btn-sm" style="border-radius: 30px;">✏️ Edit</a>
                            <form method="post" action="@Url.Action("Delete", "Resource", new { id = resource.Id })" class="d-inline">
                                <button type="submit" class="btn btn-outline-danger btn-sm" style="border-radius: 30px;">🗑️ Delete</button>
                            </form>
                        </div>
                    }<br />
                    <div class="card-body d-flex align-items-center justify-content-center" style="min-height: 200px;">
                        @if (resource.ResourceType == "PodcastAudio")
                        {
                            <audio controls class="w-100 d-flex justify-content-center">
                                <source src="@resource.Link" type="audio/mpeg">
                                Your browser does not support the audio element.
                            </audio>
                        }
                        else if (resource.ResourceType == "PodcastVideo" || resource.ResourceType == "Video")
                        {
                            <iframe class="embed-responsive-item"
                                    src="@resource.Link"
                                    allowfullscreen
                                    width="100%">
                            </iframe>
                        }
                        else if (resource.ResourceType == "Image")
                        {
                            <img src="@resource.Link" class="card-img-top img-fluid"
                                 style="max-height: 200px; object-fit: contain;"
                                 alt="@resource.Title">
                        }
                    </div>

                    <h5 class="card-title mt-3 text-center">@resource.Title</h5>
                    @if (ViewBag.UserCurent != null )
                    {
                        <form method="post" asp-action="ProvideFeedback" asp-route-resourceId="@resource.Id" class="mt-3">
                            <button type="submit" name="isLiked" value="true" class="btn btn-success btn-sm " style="border-radius: 30px; margin-left: 3%">👍 Like</button>
                            <button type="submit" name="isLiked" value="false" class="btn btn-danger btn-sm" style="border-radius: 30px;">👎 Dislike</button>
                        </form>
                    }
                    <br />
                </div>
            </div>
        }
    </div>
</div>
