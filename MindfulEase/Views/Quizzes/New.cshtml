@model MindfulEase.Models.Quiz

@{
    ViewBag.Title = "New Quiz";
}
@if (TempData.ContainsKey("message"))
{
    <h4 class="@ViewBag.Alert p-3 rounded-3 text-center mb-5">
        @ViewBag.Message
    </h4>
}

<div class="container-fluid" style="background-image: url('@Url.Content("~/img/background1.png")') !important; background-size: cover !important; background-position: center !important; min-height: 100vh; background-repeat: repeat-y; position: relative; z-index: 1;">
    <div class="row justify-content-center align-items-center" style="min-height: 100vh;">
        <div class="col-md-6">
            <section class="p-4 shadow-sm rounded" style="background-color: rgba(255, 255, 255, 0.8)">
                <h2 class="text-center" style="color: #01baa3;">Create New Quiz</h2>
                <hr />
                <p class="text-center" style="font-size: 1.1em; color: #666;">
                    Design a new quiz to engage users and help them evaluate different aspects of mindfulness!
                </p>

                @using (Html.BeginForm(actionName: "New", controllerName: "Quizzes", method: FormMethod.Post))
                {
                    @Html.AntiForgeryToken()
                    <!-- Quiz Title -->
                    <div class="mb-3">
                        <label for="Title" class="form-label fw-bold" style="color: #01baa3">Quiz Title</label>
                        @Html.TextBoxFor(model => model.Title, new { @class = "form-control", placeholder = "Enter the title of the quiz", style = "border-radius: 30px;" })
                        @Html.ValidationMessageFor(model => model.Title, "", new { @class = "text-danger" })
                    </div>

                    <!-- Quiz Description -->
                    <div class="mb-3">
                        <label for="Description" class="form-label fw-bold" style="color: #01baa3">Description</label>
                        @Html.TextAreaFor(model => model.Description, new { @class = "form-control", placeholder = "Enter a brief description", rows = 4, style = "border-radius: 30px;" })
                        @Html.ValidationMessageFor(model => model.Description, "", new { @class = "text-danger" })
                    </div>

                    <!-- Quiz Category -->
                    <div class="mb-3">
                        <label for="CategoryMapping" class="form-label fw-bold" style="color: #01baa3">Category</label>
                        @Html.TextBoxFor(model => model.CategoryMapping, new { @class = "form-control", placeholder = "Enter categories in JSON format", style = "border-radius: 30px;" })
                        @Html.ValidationMessageFor(model => model.CategoryMapping, "", new { @class = "text-danger" })
                    </div>

                    <!-- Quiz Result -->
                    <div class="mb-3">
                        <label for="Result" class="form-label fw-bold" style="color: #01baa3">Result</label>
                        @Html.TextBoxFor(model => model.Result, new { @class = "form-control", placeholder = "Enter a result for this quiz", style = "border-radius: 30px;" })
                        @Html.ValidationMessageFor(model => model.Result, "", new { @class = "text-danger" })
                    </div>

                    <!-- Quiz Background -->
                    <div class="mb-3">
                        <label for="Background" class="form-label fw-bold" style="color: #01baa3">Quiz Background Image</label>
                        @Html.TextBoxFor(model => model.Background, new { @class = "form-control", placeholder = "Enter the url for the background of the quiz", style = "border-radius: 30px;" })
                        @Html.ValidationMessageFor(model => model.Background, "", new { @class = "text-danger" })
                    </div>

                    <!-- Select Tags -->
                    <div class="mb-3">
                        <label for="Tags" class="form-label fw-bold" style="color: #01baa3">Select Tags</label>
                        <select id="Tags" name="SelectedTags" class="form-control" multiple="multiple" style="border-radius: 30px;">
                            @foreach (var tag in ViewBag.Tags as List<MindfulEase.Models.Tag>)
                            {
                                <option value="@tag.Id">@tag.Title</option>
                            }
                        </select>
                    </div>

                    @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                    <!-- Submit Button -->
                    <div class="text-center">
                        <button class="btn btn-info" type="submit" style="font-size: 1.2em; padding: 10px 30px; border-radius: 30px; color: white">
                            Create Quiz
                        </button>
                    </div>
                }
            </section>
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {
        $('#Tags').select2({
            placeholder: "Search and select tags...",
            allowClear: true
        });
    });
</script>