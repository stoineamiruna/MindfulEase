@model MindfulEase.Models.Quiz

@{
    ViewBag.Title = "Submit Quiz";
}

<div class="container-fluid" style="background-image: url('@Url.Content("~/img/quiz_background.png")'); background-size: cover; background-position: center; min-height: 100vh;">
    <div class="row justify-content-center align-items-center" style="min-height: 100vh;">
        <div class="col-md-8">
            <section class="p-4 shadow-sm rounded" style="background-color: rgba(255, 255, 255, 0.8)">
                <h2 class="text-center" style="color: #01baa3;">@Model.Title</h2>
                <p class="text-center" style="font-size: 1.1em; color: #666;">@Model.Description</p>
                <p class="text-center" style="font-size: 1.1em; color: #666;">@Model.Result</p>
                <hr />

                <h4 class="text-center" style="color: #01baa3;">Quiz Results</h4>

                @if (ViewBag.CategoryScores != null && ViewBag.CategoryScores.Count > 0)
                {
                    <div class="mt-4">
                        <h4 style="color: #01baa3;">Category Breakdown</h4>
                        <ul class="list-group">
                            @foreach (var category in ViewBag.CategoryScores)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    <strong>@category.Key</strong>
                                    <span class="badge bg-info">@category.Value</span>
                                </li>
                            }
                        </ul>
                    </div>
                }
                else
                {
                    <div class="mt-3">
                        <h5>Total Score: <span class="badge bg-primary">@ViewBag.TotalScore</span></h5>
                    </div>
                }

                <div class="mt-4 text-center">
                    <a href="@Url.Action("Index", "Quizzes")" class="btn btn-success" style="border-radius: 30px; font-size: 1.2em; padding: 10px 30px;">Back to Quizzes</a>
                </div>
            </section>
        </div>
    </div>
</div>
