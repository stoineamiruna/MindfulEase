@model MindfulEase.Models.Quiz

@{
    ViewBag.Title = "Edit Quiz";
}
@if (TempData.ContainsKey("message"))
{
    <h4 class="@ViewBag.Alert p-3 rounded-3 text-center mb-5">
        @ViewBag.Message
    </h4>
}

<div class="container-fluid" style="background-image: url('@Url.Content("~/img/background1.png")') !important; background-size: cover !important; background-position: center !important; min-height: 100vh; background-repeat: repeat-y; position: relative; z-index: 1;">
    <div class="row justify-content-center align-items-center" style="min-height: 100vh;">
        <div class="col-md-6">
            <section class="p-4 shadow-sm rounded" style="background-color: rgba(255, 255, 255, 0.8)">
                <h2 class="text-center" style="color: #01baa3;">Edit Quiz</h2>
                <hr />
                <p class="text-center" style="font-size: 1.1em; color: #666;">
                    Modify the quiz details below to keep it up to date.
                </p>

                @using (Html.BeginForm(actionName: "Edit", controllerName: "Quizzes", method: FormMethod.Post))
                {
                    @Html.AntiForgeryToken()
                    @Html.HiddenFor(model => model.Id) <!-- Hidden input for Quiz ID -->
                    <!-- Quiz Title -->
                    <div class="mb-3">
                        <label for="Title" class="form-label fw-bold" style="color: #01baa3">Quiz Title</label>
                        @Html.EditorFor(model => model.Title, new { htmlAttributes = new { @class = "form-control", placeholder = "Enter the title of the quiz", style = "border-radius: 30px;" } })
                        @Html.ValidationMessageFor(model => model.Title, null, new { @class = "text-danger" })
                    </div>

                    <!-- Quiz Description -->
                    <div class="mb-3">
                        <label for="Description" class="form-label fw-bold" style="color: #01baa3">Description</label>
                        @Html.EditorFor(model => model.Description, new { htmlAttributes = new { @class = "form-control", placeholder = "Enter a brief description", style = "border-radius: 30px;" } })
                        @Html.ValidationMessageFor(model => model.Description, null, new { @class = "text-danger" })
                    </div>

                    <!-- Quiz Category -->
                    <div class="mb-3">
                        <label for="CategoryMapping" class="form-label fw-bold" style="color: #01baa3">Category</label>
                        @Html.EditorFor(model => model.CategoryMapping, new { htmlAttributes = new { @class = "form-control", placeholder = "Enter categories in JSON format", style = "border-radius: 30px;" } })
                        @Html.ValidationMessageFor(model => model.CategoryMapping, null, new { @class = "text-danger" })
                    </div>

                    <!-- Quiz Result -->
                    <div class="mb-3">
                        <label for="Result" class="form-label fw-bold" style="color: #01baa3">Result</label>
                        @Html.EditorFor(model => model.Result, new { htmlAttributes = new { @class = "form-control", placeholder = "Enter result for this quiz", style = "border-radius: 30px;" } })
                        @Html.ValidationMessageFor(model => model.Result, null, new { @class = "text-danger" })
                    </div>

                    <!-- Quiz Background -->
                    <div class="mb-3">
                        <label for="Background" class="form-label fw-bold" style="color: #01baa3">Quiz Background URL</label>
                        @Html.EditorFor(model => model.Background, new { htmlAttributes = new { @class = "form-control", placeholder = "Enter the background image URL of the quiz", style = "border-radius: 30px;" } })
                        @Html.ValidationMessageFor(model => model.Background, null, new { @class = "text-danger" })
                    </div>

                    <!-- Select Tags -->
                    <div class="mb-3">
                        <label for="Tags" class="form-label fw-bold" style="color: #01baa3">Select Tags</label>
                        <div class="form-check">
                            @foreach (var tag in ViewBag.Tags as List<MindfulEase.Models.Tag>)
                            {
                                bool isSelected = ViewBag.SelectedTags != null && ((List<int>)ViewBag.SelectedTags).Contains(tag.Id);
                                <input class="form-check-input" type="checkbox" name="SelectedTags" value="@tag.Id" id="tag_@tag.Id" @(isSelected ? "checked" : "")>
                                <label class="form-check-label" for="tag_@tag.Id" style="color: #01baa3;">
                                    @tag.Title
                                </label>
                                <br />
                            }
                        </div>
                    </div>

                    @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                    <!-- Submit Button -->
                    <div class="text-center">
                        <button class="btn btn-info" type="submit" style="font-size: 1.2em; padding: 10px 30px; border-radius: 30px; color: white">
                            Update Quiz
                        </button>
                    </div>
                }
            </section>
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {
        $('#Tags').select2({
            placeholder: "Search and select tags...",
            allowClear: true
        });
    });
</script>