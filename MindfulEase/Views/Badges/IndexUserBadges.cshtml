@model IEnumerable<MindfulEase.Models.Badge>
@{
    ViewBag.Title = "Badges for @ViewBag.User.UserName";
}
@if (TempData.ContainsKey("message"))
{
    <h4 class="@ViewBag.Alert p-3 rounded-3 text-center mb-5">
        @ViewBag.Message
    </h4>
}

<div class="container my-5">
    @if (ViewBag.User.Id == ViewBag.UserCurent)
    {
        <h2 class="text-center mb-4">🏅 My Badges</h2>
    }
    else
    {
        <h2 class="text-center mb-4">🏅 @ViewBag.User.UserName's Badges</h2>
    }

    @foreach (var activityGroup in Model.GroupBy(b => b.Activity))
    {
        <section class="mb-5">
            <h3 class="mb-3">🏆 @activityGroup.Key</h3>
            <div class="row">
                @foreach (var badge in activityGroup)
                {
                    <div class="col-6 col-md-4 col-lg-3 mb-4 d-flex">
                        <div class="card shadow-sm text-center w-100" style="border-radius: 20px; height: 100%; display: flex; flex-direction: column; justify-content: space-between;">
                            <div style="background: white; padding: 10px; border-radius: 20px 20px 0 0;">
                                <img src="@badge.ImageUrl" class="card-img-top" alt="@badge.Title"
                                     style="height: 180px; object-fit: contain; max-width: 100%;">
                            </div>
                            <div class="card-body" style="flex-grow: 1; display: flex; flex-direction: column; justify-content: space-between; min-height: 220px;">                            
                                <h5 class="card-title">@badge.Title</h5>
                                <p class="card-text">@badge.Description</p>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </section>
    }
</div>
<br /><br /><br /><br />
<style>
    body {
        background: linear-gradient(to bottom, rgba(168, 237, 234, 0.3), rgba(254, 214, 227, 0.3));
        background-attachment: fixed;
        min-height: 100vh;
        margin: 0;
    }
</style>
