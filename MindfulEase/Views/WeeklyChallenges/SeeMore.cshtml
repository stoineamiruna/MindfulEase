@{
    ViewBag.Title = ViewBag.CategoryName;
    var challenges = ViewBag.Challenges as IEnumerable<dynamic>; ;
}

<div class="container my-5">
    <h2 class="text-center mb-4">🏆 @ViewBag.CategoryName</h2>

    <!-- Add Challenge Button (only for Admin/Moderator) -->
    @if (ViewBag.EsteAdmin || ViewBag.EsteModerator)
    {
        <div class="text-center mb-4">
            <button class="btn btn-outline-info" data-bs-toggle="modal" data-bs-target="#createChallengeModal" style="border-radius: 30px;">
                ➕ Add New Challenge
            </button>
        </div>
    }

    <div class="row">
        @if (challenges != null && challenges.Any())
        {
            @foreach (var challenge in challenges)
            {
                <div class="col-md-4 mb-4">
                    <div class="card shadow-sm text-center" style="border-radius: 20px; background-image: url('@challenge.URLBackground'); background-size: cover; background-position: center;">
                        <br />

                        <div class="card-body" style="background: rgba(255, 255, 255, 0.8); border-radius: 20px;">

                            <br />
                            <!-- Butoane Edit & Delete aliniate corect -->
                            @if (ViewBag.EsteAdmin || ViewBag.EsteModerator)
                            {
                                <div class="d-flex justify-content-between">
                                    <button class="btn btn-outline-info btn-sm" data-bs-toggle="modal" data-bs-target="#editChallengeModal-@challenge.Id" style="border-radius: 30px;">✏️</button>
                                    <form asp-action="Delete" asp-route-id="@challenge.Id" method="post" class="d-inline">
                                        <button type="submit" class="btn btn-outline-danger btn-sm" style="border-radius: 30px;">🗑️</button>
                                    </form>
                                </div>
                            }
                            <h5 class="card-title">@challenge.Title</h5>
                            <p class="card-text">@challenge.Description</p>
                            <button class="btn btn-info btn-sm" data-bs-toggle="modal" data-bs-target="#challengeModal-@challenge.Id" style="border-radius: 30px;">
                                🔍 View Details
                            </button>


                        </div>
                    </div>
                    <!-- Challenge Details Modal -->
                    <div class="modal fade" id="challengeModal-@challenge.Id" tabindex="-1">
                        <div class="modal-dialog">
                            <div class="modal-content">
                                <div class="modal-header">
                                    <h5 class="modal-title">@challenge.Title</h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                </div>
                                <div class="modal-header">
                                    @if (challenge.IsCompleted)
                                    {
                                        <h4 class="modal-title text-info">Challenge Completed ✅</h4>
                                    }
                                </div>
                                <div class="modal-body" style="background-image: url('@challenge.URLBackground'); background-size: cover; background-position: center; color: white; padding: 20px; border-radius: 10px;">

                                    <div style="background: rgba(0, 0, 0, 0.6); padding: 15px; border-radius: 10px;">
                                        <p class="text-center">@challenge.Description</p>
                                        <div class="text-center">
                                            <p><strong>Start:</strong> @challenge.StartDate.ToShortDateString()</p>
                                            <p><strong>End:</strong> @challenge.EndDate.ToShortDateString()</p>
                                            @if (challenge.RequiredPoints != null && challenge.RequiredPoints != 0)
                                            {
                                                @if (@challenge.UserPoints > @challenge.RequiredPoints)
                                                {
                                                    <p><small>🌟 Required Points:  @challenge.RequiredPoints/@challenge.RequiredPoints ✔️</small></p>
                                                }
                                                else
                                                {
                                                    <p><small>🌟 Required Points:  @challenge.UserPoints/@challenge.RequiredPoints</small></p>
                                                }
                                            }
                                            @if (challenge.RequiredJournalEntries != null && challenge.RequiredJournalEntries != 0)
                                            {
                                                @if (@challenge.UserJournalEntries > @challenge.RequiredJournalEntries)
                                                {
                                                    <p><small>📖 Required Journal Entries:  @challenge.RequiredJournalEntries/@challenge.RequiredJournalEntries ✔️</small></p>
                                                }
                                                else
                                                {
                                                    <p><small>📖 Required Journal Entries:  @challenge.UserJournalEntries/@challenge.RequiredJournalEntries</small></p>
                                                }
                                            }
                                            @if (challenge.RequiredQuizzes != null && challenge.RequiredQuizzes != 0)
                                            {
                                                @if (@challenge.UserQuizzes > @challenge.RequiredQuizzes)
                                                {
                                                    <p><small>✍ Required Quizzes:  @challenge.RequiredQuizzes/@challenge.RequiredQuizzes ✔️</small></p>
                                                }
                                                else
                                                {
                                                    <p><small>✍ Required Quizzes:  @challenge.UserJournalEntries/@challenge.RequiredJournalEntries</small></p>
                                                }
                                            }

                                        </div>

                                        @if (challenge.RequiredResources != null && challenge.RequiredResources != 0 && ViewBag.Resources != null && ((List<MindfulEase.Models.Resource>)ViewBag.Resources).Any())
                                        {
                                            <div class="mt-3">
                                                <h6 class="text-center">📚 Required Resources</h6>
                                                <div class="row">
                                                    @foreach (var resource in ((List<MindfulEase.Models.Resource>)ViewBag.Resources).Take(4))
                                                    {
                                                        <div class="col-6 col-md-4 col-lg-3 mb-3">
                                                            <div class="card shadow-sm h-100 d-flex flex-column justify-content-center" style="height: 50px;">
                                                                <div class="card-body d-flex align-items-center justify-content-center p-1" style="height: 50px;">
                                                                    @if (resource.ResourceType == "Image")
                                                                    {
                                                                        <img src="@resource.Link" class="img-fluid" style="max-height: 40px; object-fit: contain;" alt="@resource.Title">
                                                                    }
                                                                    else if (resource.ResourceType == "Video" || resource.ResourceType == "PodcastVideo")
                                                                    {
                                                                        <iframe class="embed-responsive-item"
                                                                                src="@resource.Link"
                                                                                allowfullscreen
                                                                                width="100%"
                                                                                height="40">
                                                                        </iframe>
                                                                    }
                                                                    else if (resource.ResourceType == "PodcastAudio")
                                                                    {
                                                                        <iframe src="@resource.Link" width="100%" height="40" frameborder="0" allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture" allowfullscreen></iframe>
                                                                    }
                                                                </div>
                                                                <h6 class="card-title text-center p-1 m-0" style="font-size: 0.7rem; color: black;">@resource.Title</h6>
                                                            </div>

                                                        </div>
                                                    }
                                                </div>
                                                <div class="text-center mt-2">
                                                    <a href="@Url.Action("Index", "Routines")" class="btn btn-link text-decoration-none fw-bold">VIEW MORE</a>
                                                </div>
                                            </div>
                                        }

                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="modal fade" id="editChallengeModal-@challenge.Id" tabindex="-1" aria-labelledby="editChallengeLabel-@challenge.Id" aria-hidden="true">
                        <div class="modal-dialog">
                            <div class="modal-content">
                                <div class="modal-header">
                                    <h5 class="modal-title">Edit Weekly Challenge</h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                </div>
                                <div class="modal-body">
                                    <form asp-action="Edit" method="post">
                                        <input type="hidden" name="Id" value="@challenge.Id" />
                                        <div class="mb-3">
                                            <label class="form-label">Title</label>
                                            <input type="text" name="Title" class="form-control" value="@challenge.Title" required />
                                        </div>
                                        <div class="mb-3">
                                            <label class="form-label">Description</label>
                                            <textarea name="Description" class="form-control" required>@challenge.Description</textarea>
                                        </div>
                                        <div class="mb-3">
                                            <label class="form-label">Background Image</label>
                                            <input type="text" name="URLBackground" class="form-control" value="@challenge.URLBackground" />
                                        </div>
                                        <div class="mb-3">
                                            <label class="form-label">Start Date</label>
                                            <input type="date" name="StartDate" class="form-control" value="@challenge.StartDate.ToString("yyyy-MM-dd")" required />
                                        </div>
                                        <div class="mb-3">
                                            <label class="form-label">End Date</label>
                                            <input type="date" name="EndDate" class="form-control" value="@challenge.EndDate.ToString("yyyy-MM-dd")" required />
                                        </div>
                                        <div class="mb-3">
                                            <label class="form-label">Required Points</label>
                                            <input type="number" name="RequiredPoints" class="form-control" value="@challenge.RequiredPoints" min="0" />
                                        </div>
                                        <div class="mb-3">
                                            <label class="form-label">Required Journal Entries</label>
                                            <input type="number" name="RequiredJournalEntries" class="form-control" value="@challenge.RequiredJournalEntries" min="0" />
                                        </div>
                                        <div class="mb-3">
                                            <label class="form-label">Required Quizzes</label>
                                            <input type="number" name="RequiredQuizzes" class="form-control" value="@challenge.RequiredQuizzes" min="0" />
                                        </div>
                                        <div class="mb-3">
                                            <label class="form-label">Required Resources</label>
                                            <input type="number" name="RequiredResources" class="form-control" value="@challenge.RequiredResources" min="0" />
                                        </div>
                                        <button type="submit" class="btn btn-success" style="border-radius: 30px;">Save Changes</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

            }
        }
        else
        {
            <p class="text-center text-muted">No challenges found for this category.</p>
        }
    </div>
    <!-- Create Weekly Challenge Modal -->
    <div class="modal fade" id="createChallengeModal" tabindex="-1" aria-labelledby="createChallengeLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Add New Weekly Challenge</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <form asp-action="Create" method="post">
                        <div class="mb-3">
                            <label class="form-label">Title</label>
                            <input type="text" name="Title" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Description</label>
                            <textarea name="Description" class="form-control" required></textarea>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Background Image</label>
                            <input type="text" name="URLBackground" class="form-control" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Start Date</label>
                            <input type="date" name="StartDate" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">End Date</label>
                            <input type="date" name="EndDate" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Required Points</label>
                            <input type="number" name="RequiredPoints" class="form-control" min="0" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Required Journal Entries</label>
                            <input type="number" name="RequiredJournalEntries" class="form-control" min="0" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Required Quizzes</label>
                            <input type="number" name="RequiredQuizzes" class="form-control" min="0" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Required Resources</label>
                            <input type="number" name="RequiredResources" class="form-control" min="0" />
                        </div>
                        <button type="submit" class="btn btn-primary" style="border-radius: 30px;">Create Challenge</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    body {
        background: linear-gradient(to bottom, rgba(168, 237, 234, 0.3), rgba(254, 214, 227, 0.3));
        background-attachment: fixed;
        min-height: 100vh;
        margin: 0;
    }
</style>