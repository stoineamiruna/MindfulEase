@model IEnumerable<dynamic>

@{
    ViewBag.Title = "Weekly Challenges";
    var today = DateTime.Today.ToString("yyyy-MM-dd");
}
@if (TempData.ContainsKey("message"))
{
    <h4 class="@ViewBag.Alert p-3 rounded-3 text-center mb-5">
        @ViewBag.Message
    </h4>
}


<div class="container my-5">
    <h2 class="text-center text-info mb-4">🏆 WEEKLY CHALLENGES</h2>

    <!-- Add Challenge Button (visible only for Admin/Moderator) -->
    @if (ViewBag.EsteAdmin || ViewBag.EsteModerator)
    {
        <div class="text-center mb-4">
            <button class="btn btn-info" data-bs-toggle="modal" data-bs-target="#createChallengeModal" style="border-radius: 30px; color:white;">
                ➕ Add New Challenge
            </button>
        </div>
    }

    @foreach (var category in new[] { "My Challenges", "Active Challenges", "Coming Soon", "Past Challenges" })
    {
        List<dynamic> challenges = category switch
        {
            "My Challenges" => ViewBag.MyChallenges as List<dynamic>,
            "Active Challenges" => ViewBag.ActiveChallenges as List<dynamic>,
            "Coming Soon" => ViewBag.ComingSoon as List<dynamic>,
            "Past Challenges" => ViewBag.PastChallenges as List<dynamic>,
            _ => new List<dynamic>()
        };


        if (challenges != null && challenges.Any())
        {
            <section class="mb-5">
                <h3 class="mb-3 text-info">🏅 @category</h3>
                <div class="row">
                    @foreach (var challenge in challenges.Take(6)) // Afișăm max 6 per categorie
                    {
                        <div class="col-md-4 mb-4 d-flex">
                            <div class="card shadow-sm text-center h-100 w-100 d-flex flex-column justify-content-between" style="border:3px solid #A8D7E8; border-radius: 20px; background-image: url('@challenge.URLBackground'); background-size: cover; background-position: center;">
                                <br />

                                <div class="card-body d-flex flex-column justify-content-between" style="background: rgba(255, 255, 255, 0.8); border-radius: 20px;">
                                    <!-- Edit & Delete Buttons (only for Admin/Moderator) -->
                                    @if (ViewBag.EsteAdmin || ViewBag.EsteModerator)
                                    {
                                        <div class="d-flex justify-content-between">
                                            <button class="btn btn-outline-info btn-sm" data-bs-toggle="modal" data-bs-target="#editChallengeModal-@challenge.Id" style="border-radius: 30px;">✏️</button>
                                            <form asp-action="Delete" asp-route-id="@challenge.Id" method="post" class="d-inline">
                                                <button type="submit" class="btn btn-outline-danger btn-sm" style="border-radius: 30px;">🗑️</button>
                                            </form>
                                        </div>
                                    }
                                    <h5 class="card-title">@challenge.Title</h5>
                                    <p class="card-text">@challenge.Description</p>
                                    <button class="btn btn-outline-info btn-sm" data-bs-toggle="modal" data-bs-target="#challengeModal-@challenge.Id" style="border-radius: 30px;">
                                        🔍 View Details
                                    </button>
                                </div>

                                    
                            </div>
                        </div>

                        <!-- Challenge Details Modal -->
                        <div class="modal fade" id="challengeModal-@challenge.Id" tabindex="-1">
                            <div class="modal-dialog">
                                <div class="modal-content" style="border-radius: 30px;">
                                    <div class="modal-header">                                     
                                        <h5 class="modal-title">@challenge.Title</h5>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                    </div>
                                    <div class="modal-header">
                                        @if (challenge.IsCompleted)
                                        {
                                            <h4 class="modal-title text-info">Challenge Completed ✅</h4>
                                        }
                                    </div>
                                    <div class="modal-body" style="background-image: url('@challenge.URLBackground'); background-size: cover; background-position: center; color: white; padding: 20px; border-radius: 10px;">

                                        <div style="background: rgba(0, 0, 0, 0.6); padding: 15px; border-radius: 10px;">
                                            <p class="text-center">@challenge.Description</p>
                                            <div class="text-center">
                                                <p><strong>Start:</strong> @challenge.StartDate.ToShortDateString()</p>
                                                <p><strong>End:</strong> @challenge.EndDate.ToShortDateString()</p>
                                                @if (challenge.RequiredPoints != null && challenge.RequiredPoints != 0)
                                                {
                                                    @if (@challenge.UserPoints > @challenge.RequiredPoints)
                                                    {
                                                        <p><small>🌟 Required Points:  @challenge.RequiredPoints/@challenge.RequiredPoints ✔️</small></p>
                                                    }
                                                    else
                                                    {
                                                        <p><small>🌟 Required Points:  @challenge.UserPoints/@challenge.RequiredPoints</small></p>
                                                    }
                                                }
                                                @if (challenge.RequiredJournalEntries != null && challenge.RequiredJournalEntries != 0)
                                                {
                                                    @if (@challenge.UserJournalEntries > @challenge.RequiredJournalEntries)
                                                    {
                                                        <p><small>📖 Required Journal Entries:  @challenge.RequiredJournalEntries/@challenge.RequiredJournalEntries ✔️</small></p>
                                                    }
                                                    else
                                                    {
                                                        <p><small>📖 Required Journal Entries:  @challenge.UserJournalEntries/@challenge.RequiredJournalEntries</small></p>
                                                    }
                                                }
                                                @if (challenge.RequiredQuizzes != null && challenge.RequiredQuizzes != 0)
                                                {
                                                    @if (@challenge.UserQuizzes > @challenge.RequiredQuizzes)
                                                    {
                                                        <p><small>✍ Required Quizzes:  @challenge.RequiredQuizzes/@challenge.RequiredQuizzes ✔️</small></p>
                                                    }
                                                    else
                                                    {
                                                        <p><small>✍ Required Quizzes:  @challenge.UserJournalEntries/@challenge.RequiredJournalEntries</small></p>
                                                    }
                                                }
                                                
                                            </div>

                                            @if (challenge.RequiredResources != null && challenge.RequiredResources != 0 && ViewBag.Resources != null && ((List<MindfulEase.Models.Resource>)ViewBag.Resources).Any())
                                            {
                                                <div class="mt-3">
                                                    <h6 class="text-center">📚 Required Resources</h6>
                                                    <div class="row">
                                                        @foreach (var resource in ((List<MindfulEase.Models.Resource>)ViewBag.Resources).Take(4))
                                                        {
                                                            <div class="col-6 col-md-4 col-lg-3 mb-3">
                                                                <div class="card shadow-sm h-100 d-flex flex-column justify-content-center" style="height: 50px;">
                                                                    <div class="card-body d-flex align-items-center justify-content-center p-1" style="height: 50px;">
                                                                        @if (resource.ResourceType == "Image")
                                                                        {
                                                                            <img src="@resource.Link" class="img-fluid" style="max-height: 40px; object-fit: contain;" alt="@resource.Title">
                                                                        }
                                                                        else if (resource.ResourceType == "Video" || resource.ResourceType == "PodcastVideo")
                                                                        {
                                                                            <iframe class="embed-responsive-item"
                                                                                    src="@resource.Link"
                                                                                    allowfullscreen
                                                                                    width="100%"
                                                                                    height="40">
                                                                            </iframe>
                                                                        }
                                                                        else if (resource.ResourceType == "PodcastAudio")
                                                                        {
                                                                            <iframe src="@resource.Link" width="100%" height="40" frameborder="0" allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture" allowfullscreen></iframe>
                                                                        }
                                                                    </div>
                                                                    <h6 class="card-title text-center p-1 m-0" style="font-size: 0.7rem; color: black;">@resource.Title</h6>
                                                                </div>

                                                            </div>
                                                        }
                                                    </div>
                                                    <div class="text-center mt-2">
                                                        <a href="@Url.Action("Index", "Routines")" class="btn btn-link text-decoration-none fw-bold">VIEW MORE</a>
                                                    </div>
                                                </div>
                                            }

                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>



                        <!-- Edit Challenge Modal -->
                        <div class="modal fade" id="editChallengeModal-@challenge.Id" tabindex="-1" aria-labelledby="editChallengeLabel-@challenge.Id" aria-hidden="true">
                            <div class="modal-dialog">
                                <div class="modal-content" style="border-radius: 30px;">
                                    <div class="modal-header">
                                        <h5 class="modal-title">Edit Weekly Challenge</h5>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                    </div>
                                    <div class="modal-body">
                                        <form asp-action="Edit" method="post">
                                            <input type="hidden" name="Id" value="@challenge.Id" />
                                            <div class="mb-3">
                                                <label  for="Title1" class="form-label">Title</label>
                                                <input id="Title1" style="border-radius: 30px;" type="text" name="Title" class="form-control" value="@challenge.Title" required />
                                            </div>
                                            <div class="mb-3">
                                                <label for="Description1" class="form-label">Description</label>
                                                <textarea id="Description1" style="border-radius: 30px;" name="Description" class="form-control" required>@challenge.Description</textarea>
                                            </div>
                                            <div class="mb-3">
                                                <label for="URLBackground1"class="form-label">Background Image</label>
                                                <input id="URLBackground1" type="text" name="URLBackground" class="form-control" value="@challenge.URLBackground" />
                                            </div>
                                            <div class="mb-3">
                                                <label for="StartDate1" class="form-label">Start Date</label>
                                                <input id="StartDate1" style="border-radius: 30px;" type="date" name="StartDate" class="form-control" value="@challenge.StartDate.ToString("yyyy-MM-dd")" required />
                                            </div>
                                            <div class="mb-3">
                                                <label for="EndDate1" class="form-label">End Date</label>
                                                <input id="EndDate1"style="border-radius: 30px;" type="date" name="EndDate" class="form-control" value="@challenge.EndDate.ToString("yyyy-MM-dd")" required />
                                            </div>
                                            <div class="mb-3">
                                                <label for="RequiredPoints1"class="form-label">Required Points</label>
                                                <input id="RequiredPoints1"style="border-radius: 30px;" type="number" name="RequiredPoints" class="form-control" value="@challenge.RequiredPoints" min="0" />
                                            </div>
                                            <div class="mb-3">
                                                <label for="RequiredJournalEntries1"class="form-label">Required Journal Entries</label>
                                                <input id="RequiredJournalEntries1"style="border-radius: 30px;" type="number" name="RequiredJournalEntries" class="form-control" value="@challenge.RequiredJournalEntries" min="0" />
                                            </div>
                                            <div class="mb-3">
                                                <label for="RequiredQuizzes1" class="form-label">Required Quizzes</label>
                                                <input id="RequiredQuizzes1"style="border-radius: 30px;" type="number" name="RequiredQuizzes" class="form-control" value="@challenge.RequiredQuizzes" min="0" />
                                            </div>
                                            <div class="mb-3">
                                                <label for="RequiredResources1" class="form-label">Required Resources</label>
                                                <input id="RequiredResources1" style="border-radius: 30px;" type="number" name="RequiredResources" class="form-control" value="@challenge.RequiredResources" min="0" />
                                            </div>
                                            <button type="submit" class="btn btn-info" style="border-radius: 30px; color:white;">Save Changes</button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <!-- See More Button -->
                <div>
                    <a asp-action="SeeMore" asp-route-category="@category" class="btn btn-outline-secondary" style="border-radius: 30px;">See More</a>
                </div>
            </section>
        }
    }

    <!-- Create Weekly Challenge Modal -->
    <div class="modal fade" id="createChallengeModal" tabindex="-1" aria-labelledby="createChallengeLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content" style="border-radius: 30px;">
                <div class="modal-header">
                    <h5 class="modal-title">Add New Weekly Challenge</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <form asp-action="Create" method="post">
                        @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                        <div class="mb-3">
                            <label for="Title" class="form-label">Title</label>
                            <input id="Title "style="border-radius: 30px;" type="text" name="Title" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label for="Description "class="form-label">Description</label>
                            <textarea id="Description" style="border-radius: 30px;" name="Description" class="form-control" required></textarea>
                        </div>
                        <div class="mb-3">
                            <label for="URLBackground" class="form-label">Background Image</label>
                            <input id="URLBackground" style="border-radius: 30px;" type="text" name="URLBackground" class="form-control" />
                        </div>
                        <div class="mb-3">
                            <label for="StartDate" class="form-label">Start Date</label>
                            <input id="StartDate" style="border-radius: 30px;" type="date" name="StartDate" class="form-control" required min="@today" />
                        </div>
                        <div class="mb-3">
                            <label for="EndDate" class="form-label">End Date</label>
                            <input id="EndDate" style="border-radius: 30px;" type="date" name="EndDate" class="form-control" required min="@today" />
                        </div>
                        <div class="mb-3">
                            <label for="RequiredPoints" class="form-label">Required Points</label>
                            <input id="RequiredPoints" style="border-radius: 30px;" type="number" name="RequiredPoints" class="form-control" min="0" />
                        </div>
                        <div class="mb-3">
                            <label for="RequiredJournalEntries" class="form-label">Required Journal Entries</label>
                            <input id="RequiredJournalEntries" style="border-radius: 30px;" type="number" name="RequiredJournalEntries" class="form-control" min="0" />
                        </div>
                        <div class="mb-3">
                            <label for="RequiredQuizzes" class="form-label">Required Quizzes</label>
                            <input id="RequiredQuizzes" style="border-radius: 30px;" type="number" name="RequiredQuizzes" class="form-control" min="0" />
                        </div>
                        <div class="mb-3">
                            <label for="RequiredResources" class="form-label">Required Resources</label>
                            <input id="RequiredResources" style="border-radius: 30px;" type="number" name="RequiredResources" class="form-control" min="0" />
                        </div>
                        <button type="submit" class="btn btn-info" style="border-radius: 30px; color:white;">Create Challenge</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
    
</div>

<style>
    body {
        background: linear-gradient(to bottom, rgba(168, 237, 234, 0.3), rgba(254, 214, 227, 0.3));
        background-attachment: fixed;
        min-height: 100vh;
        margin: 0;
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const startInput = document.getElementById('StartDate');
        const endInput = document.getElementById('EndDate');
        const startInput1 = document.getElementById('StartDate1');
        const endInput1 = document.getElementById('EndDate1');

        // Actualizează min endDate când selectezi startDate
        startInput.addEventListener('change', function () {
            endInput.min = this.value;

            // Dacă endDate este înainte de startDate, resetează-l
            if (endInput.value < this.value) {
                endInput.value = this.value;
            }
        });
        startInput1.addEventListener('change', function () {
            endInput1.min = this.value;

            // Dacă endDate este înainte de startDate, resetează-l
            if (endInput1.value < this.value) {
                endInput1.value = this.value;
            }
        });
    });
</script>