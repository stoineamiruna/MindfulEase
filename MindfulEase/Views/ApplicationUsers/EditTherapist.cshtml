@model MindfulEase.Models.ApplicationUser
@{
    ViewBag.Title = "Edit Your Therapist Profile";
}

<div class="container-fluid" style="background-image: url('@Url.Content("~/img/NewProfile.jpg")') !important; background-size: cover !important; background-position: center !important; min-height: 100vh; display: flex; flex-direction: column; justify-content: flex-start;">
    <div class="row justify-content-start align-items-center" style="height: 100%;">
        <div class="col-md-6">
            <section class="p-4 shadow-sm rounded" style="background-color: rgba(240, 248, 255, 0.7)">
                <h2 class="text-center" style="color: #01baa3">Edit Your Therapist Profile</h2>
                <hr />
                <p class="text-center" style="font-size: 1.1em; color: #666;">
                    Update your therapist profile information below to continue helping others on their wellness journey.
                </p>

                @using (Html.BeginForm(actionName: "EditTherapist", controllerName: "ApplicationUsers", method: FormMethod.Post, routeValues: new { id = Model.Id }))
                {
                    <!-- First Name -->
                    <div class="mb-3">
                        <label for="FirstName" class="form-label fw-bold" style="color: #01baa3">First Name</label>
                        @Html.Editor("FirstName", new { htmlAttributes = new { @class = "form-control", style = "border-radius: 30px;" } })
                        @Html.ValidationMessageFor(m => m.FirstName, null, new { @class = "text-danger" })
                    </div>

                    <!-- Last Name -->
                    <div class="mb-3">
                        <label for="LastName" class="form-label fw-bold" style="color: #01baa3">Last Name</label>
                        @Html.Editor("LastName", new { htmlAttributes = new { @class = "form-control", style = "border-radius: 30px;" } })
                        @Html.ValidationMessageFor(m => m.LastName, null, new { @class = "text-danger" })
                    </div>

                    <!-- Description -->
                    <div class="mb-3">
                        <label for="Description" class="form-label fw-bold" style="color: #01baa3">Tell us about your practice 𓂃🖊</label>
                        @Html.Editor("Description", new { htmlAttributes = new { @class = "form-control", style = "height: 150px; border-radius: 30px;" } })
                        @Html.ValidationMessageFor(m => m.Description, null, new { @class = "text-danger" })
                    </div>

                    <!-- Profile Picture -->
                    <div class="mb-3">
                        <label for="ProfilePicture" class="form-label fw-bold" style="color: #01baa3">Profile Picture</label>
                        @Html.Editor("ProfilePicture", new { htmlAttributes = new { @class = "form-control", style = "border-radius: 30px;" } })
                        @Html.ValidationMessageFor(m => m.ProfilePicture, null, new { @class = "text-danger" })
                    </div>

                    <!-- Birthday -->
                    <div class="mb-3">
                        <label for="Birthday" class="form-label fw-bold" style="color: #01baa3">Birthday 🎉</label>
                        @Html.Editor("Birthday", new { htmlAttributes = new { @class = "form-control", style = "border-radius: 30px;" } })
                        @Html.ValidationMessageFor(m => m.Birthday, null, new { @class = "text-danger" })
                    </div>

                    <!-- Studies -->
                    <div class="mb-3">
                        <label for="Studies" class="form-label fw-bold" style="color: #01baa3">Your Studies 📚</label>
                        @Html.Editor("Studies", new { htmlAttributes = new { @class = "form-control", style = "border-radius: 30px;" } })
                        @Html.ValidationMessageFor(m => m.Studies, null, new { @class = "text-danger" })
                    </div>

                    <!-- Phone Number -->
                    <div class="mb-3">
                        <label for="PhoneNumber" class="form-label fw-bold" style="color: #01baa3">Phone Number 📞</label>
                        @Html.Editor("PhoneNumber", new { htmlAttributes = new { @class = "form-control", style = "border-radius: 30px;" } })
                        @Html.ValidationMessageFor(m => m.PhoneNumber, null, new { @class = "text-danger" })
                    </div>

                    <!-- Background Color -->
                    <div class="mb-3">
                        <label for="BackgroundColor" class="form-label fw-bold" style="color: #01baa3">Preferred Background Color</label>
                        @Html.Editor("BackgroundColor", new { htmlAttributes = new { @class = "form-control", style = "border-radius: 30px;" } })
                        @Html.ValidationMessageFor(m => m.BackgroundColor, null, new { @class = "text-danger" })
                    </div>
                    <!-- Sex -->
                    <div class="mb-3">
                        <label for="Sex" class="form-label fw-bold" style="color: #01baa3">Sex</label>
                        @Html.DropDownListFor(m => m.Sex, new SelectList(new[]            {
                            new { Value = "", Text = "Unspecified" },
                            new { Value = "F", Text = "Female" },
                            new { Value = "M", Text = "Male" }
                            }, "Value", "Text", Model.Sex), htmlAttributes: new { @class = "form-control", style = "border-radius: 30px;" })
                        @Html.ValidationMessageFor(m => m.Sex, null, new { @class = "text-danger" })
                    </div>

                    <br />

                    <div class="text-center">
                        <button class="btn btn-info" type="submit" style="font-size: 1.2em; padding: 10px 30px; border-radius: 30px; color: white">Apply Changes</button>
                    </div>

                    <br />

                }
            </section>
        </div>
    </div>
</div>
<br /><br />
