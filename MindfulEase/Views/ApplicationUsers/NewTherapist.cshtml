@model MindfulEase.Models.ApplicationUser

@{
    ViewBag.Title = "Create Your Therapist Profile";
}
@if (TempData.ContainsKey("message"))
{
    <h4 class="@ViewBag.Alert p-3 rounded-3 text-center mb-5">
        @ViewBag.Message
    </h4>
}


<div class="container-fluid" style="background-image: url('@Url.Content("~/img/NewProfile.jpg")') !important; background-size: cover !important; background-position: center !important; min-height: 100vh; display: flex; flex-direction: column; justify-content: center;">
    <div class="row justify-content-start align-items-center" style="height: 100%;">
        <div class="col-md-6">
            <section class="p-4 shadow-sm rounded" style="background-color: rgba(240, 248, 255, 0.7)">
                <h2 class="text-center newProfile" style="color: #01baa3">Create Your Therapist Profile</h2>
                <hr />
                <p class="text-center" style="font-size: 1.1em; color: #666;">
                    Please share your details to help us understand your background and practice as a therapist.
                </p>

                @using (Html.BeginForm(actionName: "NewTherapist", controllerName: "ApplicationUsers", method: FormMethod.Post))
                {
                    @Html.AntiForgeryToken()
                    <!-- First Name -->
                    <div class="mb-3">
                        <label for="FirstName" class="form-label fw-bold" style="color: #01baa3">First Name</label>
                        @Html.TextBoxFor(m => m.FirstName, new { @class = "form-control", placeholder = "Enter your first name", style = "border-radius: 30px;" })
                        @Html.ValidationMessageFor(m => m.FirstName, "", new { @class = "text-danger" })
                    </div>

                    <!-- Last Name -->
                    <div class="mb-3">
                        <label for="LastName" class="form-label fw-bold" style="color: #01baa3">Last Name</label>
                        @Html.TextBoxFor(m => m.LastName, new { @class = "form-control", placeholder = "Enter your last name", style = "border-radius: 30px;" })
                        @Html.ValidationMessageFor(m => m.LastName, "", new { @class = "text-danger" })
                    </div>

                    <!-- Description -->
                    <div class="mb-3">
                        <label for="Description" class="form-label fw-bold" style="color: #01baa3">Tell us about your practice 𓂃🖊</label>
                        @Html.TextAreaFor(m => m.Description, new { @class = "form-control", placeholder = "A short description of yourself", style = "height: 150px; border-radius: 30px; " })
                        @Html.ValidationMessageFor(m => m.Description, "", new { @class = "text-danger" })
                    </div>

                    <!-- Birthday -->
                    <div class="mb-3">
                        <label for="Birthday" class="form-label fw-bold" style="color: #01baa3">Birthday 🎉</label>
                        <input type="date" max="@DateTime.Today.AddYears(-8).ToString("yyyy-MM-dd")" name="Birthday" id="Birthday" class="form-control" style="border-radius: 30px;" value="@Model.Birthday?.ToString("yyyy-MM-dd")" />
                        @Html.ValidationMessageFor(m => m.Birthday, null, new { @class = "text-danger" })
                    </div>

                    <!-- Profile Picture -->
                    <div class="mb-3">
                        <label for="ProfilePicture" class="form-label fw-bold" style="color: #01baa3">Profile Picture</label>
                        @Html.TextBoxFor(m => m.ProfilePicture, new { @class = "form-control", placeholder = "Provide a link to your profile picture", style = "border-radius: 30px; " })
                        @Html.ValidationMessageFor(m => m.ProfilePicture, null, new { @class = "text-danger" })
                    </div>

                    <!-- Studies -->
                    <div class="mb-3">
                        <label for="Studies" class="form-label fw-bold" style="color: #01baa3">Your Studies 📚</label>
                        @Html.TextBoxFor(m => m.Studies, new { @class = "form-control", placeholder = "Provide your educational background", style = "border-radius: 30px; " })
                        @Html.ValidationMessageFor(m => m.Studies, null, new { @class = "text-danger" })
                    </div>

                    <!-- Phone Number -->
                    <div class="mb-3">
                        <label for="PhoneNumber" class="form-label fw-bold" style="color: #01baa3">Phone Number 📞</label>
                        @Html.TextBoxFor(m => m.PhoneNumber, new { @class = "form-control", placeholder = "Enter your phone number", style = "border-radius: 30px; " })
                        @Html.ValidationMessageFor(m => m.PhoneNumber, null, new { @class = "text-danger" })
                    </div>

                    <!-- Background Color -->
                    <div class="mb-3">
                        <label for="BackgroundColor" class="form-label fw-bold" style="color: #01baa3">Preferred Background Color</label>
                        @Html.TextBoxFor(m => m.BackgroundColor, new { @class = "form-control", placeholder = "Choose a background color for your profile", style = "border-radius: 30px; " })
                        @Html.ValidationMessageFor(m => m.BackgroundColor, null, new { @class = "text-danger" })
                    </div>

                    <!-- Sex -->
                    <div class="mb-3">
                        <label for="Sex" class="form-label fw-bold" style="color: #01baa3">Sex</label>
                        <select class="form-control" name="Sex" id="Sex" style="border-radius: 30px;">
                            <option value="">Unspecified</option>
                            <option value="F">Female</option>
                            <option value="M">Male</option>
                        </select>
                    </div>

                    @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                    <!-- Button -->
                    <div class="text-center">
                        <button class="btn btn-info" type="submit" style="font-size: 1.2em; padding: 10px 30px; border-radius: 30px; color: white">Create My Therapist Profile</button>
                    </div>
                    <br />
                }
            </section>
        </div>
    </div>
</div>
<br />
<br />