@{
    ViewBag.Title = "Brain Visualization";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@section Styles {
    <link rel="stylesheet" href="~/css/brain.css" asp-append-version="true" />
}
<script>
    const emotionsData = @Html.Raw(ViewBag.EmotionsByDate ?? "[]");
</script>
@section Scripts {
    <script type="module" src="/js/brainVisualization.js?v=@DateTime.Now.Ticks"></script>
    
    @*<script type="module" src="~/js/brainVisualization.js"></script>*@

}


<div style="display: flex; flex-direction: row; height: 100vh;">
    <!-- Stânga: Canvas Three.js -->
    <div style="flex: 2; background: transparent; position:relative;">
        <canvas id="brainCanvas"></canvas>
        <div id="emotionLegend"></div>

        <!-- Butoane de navigare în dreapta jos -->
        <div id="navigationControls">
            <button id="pan-up">↑</button>
            <button id="pan-left">←</button>
            <button id="pan-right">→</button>
            <button id="pan-down">↓</button>
            <button id="zoom-in">＋</button>
            <button id="zoom-out">－</button>

        </div>
    </div>

    <!-- Dreapta: UI Tabs -->
    <div class="right" style="color: #088aa7; flex: 1.2; margin-right: 1%; padding: 20px; overflow-y: auto; border-radius: 25px; border:3px solid #A8D7E8;">
        <div style="display: flex; gap: 10px; margin-bottom: 20px;">
            <button id="tabInformative" class="tab-btn active" style="border-radius: 25px;">Informative</button>
            <button id="tabMyBrain" class="tab-btn" style="border-radius: 25px;">My Brain</button>
            <button id="tabBrainProjection" class="tab-btn" style="border-radius: 25px;">Brain Projection</button>
        </div>

        <div id="informativePanel">
            <h2>Understanding Emotions in the Brain</h2>
            <p>
                Emotions activate specific regions in the brain. Through this interactive 3D model, you can explore how emotions like <strong style="color:#F6BE00">joy </strong>, <strong style="color:blue">sadness</strong>, <strong style="color:magenta">fear</strong>, and <strong style="color:red">anger</strong> influence the brain's structure.
            </p>

            <!-- Selector de Emoții -->
            <div id="emotionSelector" style="margin: 20px 0;">
                <h3>Select an Emotion</h3>
                <p style="margin-bottom: 10px;">Choose an emotion to see which brain regions are most involved:</p>
                <div style="display: flex; flex-wrap: wrap; gap: 10px;">
                    <button class="emotion-btn active" data-emotion="global" title="All regions (default)">🌐</button>
                    <button class="emotion-btn" data-emotion="joy" title="Joy">😊</button>
                    <button class="emotion-btn" data-emotion="sadness" title="Sadness">😢</button>
                    <button class="emotion-btn" data-emotion="anger" title="Anger">😠</button>
                    <button class="emotion-btn" data-emotion="love" title="Love">😍</button>
                    <button class="emotion-btn" data-emotion="fear" title="Fear">😱</button>
                    <button class="emotion-btn" data-emotion="surprise" title="Surprise">😲</button>
                    <button class="emotion-btn" data-emotion="disgust" title="Disgust">🤢</button>
                </div>
            </div>
            @*
            <p>
                Each highlighted region corresponds to neural activity related to that emotion. You can hover or click on brain areas for additional info.
            </p>
            <ul>
                <li>Click an emoji to view related brain regions.</li>
                <li>Hover over a brain region to discover its role.</li>
                <li>Observe how emotions interact with brain structure.</li>
            </ul>*@
            <div id="emotionDescription" style="margin-top: 20px;">
                <!-- Textul va fi actualizat dinamic aici -->
            </div>

        </div>


        <div id="myBrainPanel" style="display: none;">
            <h2>My Brain – Emotional Footprint</h2>

            <!-- Indicație pentru utilizator -->
            <div style="margin-bottom: 20px;">
                <p><strong>Select a date to view your brain's emotional activity:</strong> This will highlight regions in your brain based on emotions detected over time. Choose a date to explore!</p>
            </div>

            <!-- Selectare perioadă cu design îmbunătățit -->
            <div style="margin-bottom: 20px;">
                <label for="emotionDatePicker" class="form-label">Select a date:</label><br />
                <input style="border-radius: 30px; color:#088aa7;" type="date" max="@DateTime.Today.ToString("yyyy-MM-dd")" id="emotionDatePicker" name="emotionDatePicker" class="form-control" />
            </div>

            <!-- Harta emoțiilor -->
            <div style="margin-bottom: 20px;">
                <h4>Emotion Map</h4>
                <p>Based on the selected date, we will highlight brain regions affected by various emotions. Emotions such as joy, sadness, fear, and anger impact different areas of the brain.</p>
            </div>

            <!-- Buton pentru Brain Damage -->
            <div style="margin-bottom: 20px;">
                <button style="border-radius: 30px; color:white;"id="viewBrainDamageButton" class="btn btn-warning" disabled>View Brain Damage</button>
                <p >Click to see the potential impact of emotional activities (such as fear, anger, etc.) on your brain regions.</p>
            </div>
            <br />

            <!-- Slider predicție viitoare -->
            <div style="margin-bottom: 20px;">
                <label for="predictSlider" class="form-label">Predict my brain in:</label><br />
                <input type="range" id="predictSlider" min="0" max="10" step="1" value="0" class="form-range" />
                <span id="predictYears">0 years</span>

            </div>

            <button id="showPredictionInfoBtn1" style="display: none; border-radius: 30px; color:white;" class="btn btn-info">Show Prediction Details</button>
            <div id="loadingSpinner1" class="text-center" style="display: none;">
                <div class="spinner-border text-info" role="status" style="width: 2.5rem; height: 2.5rem;">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>

            <br />
            <!-- Scor de uzură / risc -->
            <div id="riskSummary" style="margin-top: 20px;">
                <h4 class="text-danger">Risk Overview</h4>
                <ul id="riskList">
                    <!-- Va fi umplut dinamic din JavaScript -->
                </ul>
                <p id="noRiskMessage" style="display: none; color: #f00;">No regions are at risk based on the selected emotions.</p>
            </div>

            <!-- Badge regiuni echilibrate -->
            <div id="balancedRegions" style="margin-top: 20px;">
                <h4 class="text-success">Balanced Regions</h4>
                <p id="balancedRegionsText">You're doing great! These regions are stable over time:</p>
                <ul id="balancedList"></ul>
                <p id="noBalancedMessage" style="display: none; color: #28a745;">No balanced brain regions were found based on the selected emotional profile. This means that no regions were identified as being in a neutral state with respect to the chosen emotions.</p>
            </div>
        </div>

        <div id="brainProjectionPanel" style="display: none;">
            <h2>Brain Projection – Future Outlook</h2>

            <!-- Funcțional: Slider și buton -->
            <div style="margin-bottom: 20px;">
                <label for="projectionSlider" class="form-label">Predict my brain in:</label><br />
                <input type="range" id="projectionSlider" min="0" max="10" step="1" value="0" class="form-range" />
                <span id="projectionYears">0 years</span>
            </div>

            <div id="projectionResult" style="margin-top: 20px;">
                <p>Your brain projection will be displayed here based on your emotional history and the selected years.</p>
            </div>

            <br />
            <button id="showPredictionInfoBtn2" style="display: none; border-radius: 30px; color:white;" class="btn btn-info">Show Prediction Details</button>
            <div id="loadingSpinner2" class="text-center" style="display: none;">
                <div class="spinner-border text-info" role="status" style="width: 2.5rem; height: 2.5rem;">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>
            <!-- Informații explicative afișate permanent -->
            <div id="brainInfoContent" style="margin-top: 30px;">
                <h4>About this Brain Projection</h4>
                <p>
                    This feature leverages a <strong>machine learning model trained on the NKI-Rockland Sample (NKI-RS)</strong> dataset — a comprehensive, open-access
                    neuroimaging collection used in research on brain development and mental health.
                </p>

                <p>
                    Your current emotional profile is processed using a <strong>weighted average of your emotional history</strong>, with more recent experiences
                    carrying greater influence. Based on this and the selected future timeframe (via the slider), we simulate how key brain regions might be impacted.
                </p>

                <p>
                    The resulting prediction shows possible stress or dysregulation in areas such as the <em>Amygdala</em>, <em>Prefrontal Cortex</em>, and
                    <em>Hippocampus</em> — regions known for their role in emotion, memory, and regulation.
                </p>

                <div style="margin: 15px 0; padding: 10px; background-color: #f5f5f5; border-left: 5px solid #0dcaf0;">
                    <strong>Did you know?</strong><br />
                    Research indicates that <strong>chronic emotional stress over 5–10 years</strong> can lead to measurable changes in brain structure and function.
                    Early awareness supports better mental health outcomes.
                </div>

                <p>
                    This projection is not a diagnosis, but a tool for awareness. The accompanying report includes personalized recommendations
                    to help maintain or restore emotional brain balance based on predicted risk.
                </p>
            </div>
        </div>


    </div>
</div>
<br /><br /><br />
<!-- Modală informativă pentru regiuni cerebrale -->
<div id="regionModal" class="custom-modal">
    <div class="custom-modal-content">
        <span class="custom-modal-close" onclick="document.getElementById('regionModal').style.display='none'">&times;</span>

        <h3 id="regionTitle" class="custom-modal-title">Brain Region Info</h3>

        <div id="regionInfo" class="custom-modal-body"></div>

        <button class="custom-modal-button" onclick="document.getElementById('regionModal').style.display='none'">
            Close
        </button>
    </div>
</div>

<!-- Modala pentru informații despre preziceri tab 1 -->
<div id="predictionModal1" class="custom-modal">
    <div class="custom-modal-content">
        <span class="custom-modal-close" onclick="document.getElementById('predictionModal1').style.display='none'">&times;</span>

        <h3 id="predictionModalTitle1" class="custom-modal-title">Prediction Information</h3>

        <div id="predictionModalContent1" class="custom-modal-body"></div>

        <button class="custom-modal-button" onclick="document.getElementById('predictionModal1').style.display='none'">
            Close
        </button>
    </div>
</div>
<!-- Modala pentru informații despre preziceri tab 2-->
<div id="predictionModal2" class="custom-modal">
    <div class="custom-modal-content">
        <span class="custom-modal-close" onclick="document.getElementById('predictionModal2').style.display='none'">&times;</span>

        <h3 id="predictionModalTitle2" class="custom-modal-title">Prediction Information</h3>

        <div id="predictionModalContent2" class="custom-modal-body"></div>

        <button class="custom-modal-button" onclick="document.getElementById('predictionModal2').style.display='none'">
            Close
        </button>
    </div>
</div>
