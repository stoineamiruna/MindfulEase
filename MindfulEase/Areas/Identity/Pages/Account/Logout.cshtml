@page
@model LogoutModel
@{
    ViewData["Title"] = "Log out";
}
<div class="container min-vh-100 d-flex align-items-center justify-content-center">
    <div class="card shadow-lg p-4 text-center" style="max-width: 500px; border-radius: 30px;">
        <h3 class="mb-3">@ViewData["Title"]</h3>
        @if (User.Identity?.IsAuthenticated ?? false)
        {
            <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/", new { area = "" })" method="post">
                <button type="submit" class="btn btn-gradient">Click here to Logout</button>
            </form>
        }
        else
        {
            <p class="text-success">You have successfully logged out of the application.</p>
        }
    </div>
</div>
