@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Forgot your password?";
}
<div class="container min-vh-100">
    <div class="card shadow-lg p-4" style="max-width: 500px; margin: auto; border-radius: 30px;">
        <h3 class="text-center mb-4">@ViewData["Title"]</h3>
        <p class="text-center text-muted">Enter your email and we'll send a link to reset your password.</p>
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <div class="form-floating mb-3">
                <input asp-for="Input.Email" class="form-control" autocomplete="username" />
                <label asp-for="Input.Email"></label>
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>
            <button type="submit" class="w-100 btn btn-lg btn-gradient">Reset Password</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
